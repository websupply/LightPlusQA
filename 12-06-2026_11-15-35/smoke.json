              "exec": [
                "// @PED_CAT @smoke - Criacao valida simples\r",
                "// Valida contrato completo de retorno da API\r",
                "\r",
                "pm.test(\"Status HTTP deve ser 200\", function () {\r",
                "    pm.response.to.have.status(200);\r",
                "});\r",
                "\r",
                "if (pm.response && pm.response.code === 200){\r",
                "\r",
                "    const json = pm.response.json();\r",
                "\r",
                "    // 1️⃣ Estrutura principal\r",
                "    pm.test(\"Envelope Mensagem existe\", function () {\r",
                "        pm.expect(json).to.have.property(\"Mensagem\");\r",
                "    });\r",
                "\r",
                "    pm.test(\"Envelope Requisicao existe\", function () {\r",
                "        pm.expect(json).to.have.property(\"Requisicao\");\r",
                "    });\r",
                "\r",
                "    // 2️⃣ Mensagem\r",
                "    pm.test(\"Mensagem.Tipo deve ser success\", function () {\r",
                "        pm.expect(json.Mensagem.Tipo).to.eql(\"success\");\r",
                "    });\r",
                "\r",
                "    pm.test(\"Mensagem.Titulo deve existir\", function () {\r",
                "        pm.expect(json.Mensagem).to.have.property(\"Titulo\");\r",
                "    });\r",
                "\r",
                "    // 3️⃣ Retorno interno\r",
                "    pm.test(\"Requisicao.Retorno existe\", function () {\r",
                "        pm.expect(json.Requisicao).to.have.property(\"Retorno\");\r",
                "    });\r",
                "\r",
                "    pm.test(\"NumeroPedidoWebsupply retornado\", function () {\r",
                "        pm.expect(json.Requisicao.Retorno.numeroPedidoWebsupply || \r",
                "                  json.Requisicao.Retorno.NumeroPedidoWebsupply)\r",
                "            .to.not.be.empty;\r",
                "    });\r",
                "\r",
                "    pm.test(\"NumeroPedidoLight retornado corretamente\", function () {\r",
                "        pm.expect(\r",
                "            json.Requisicao.Retorno.numeroPedidoLight ||\r",
                "            json.Requisicao.Retorno.NumeroPedidoLight\r",
                "        ).to.eql(pm.request.body.raw ? JSON.parse(pm.request.body.raw).numeroPedidoLight : undefined);\r",
                "    });\r",
                "\r",
                "    // 4️⃣ Status interno\r",
                "    pm.test(\"Status interno deve ser 200\", function () {\r",
                "        pm.expect(json.Requisicao.Status).to.eql(200);\r",
                "    });\r",
                "\r",
                "    // 5️⃣ Link referência\r",
                "    pm.test(\"Link_Referencia presente\", function () {\r",
                "        pm.expect(json.Requisicao).to.have.property(\"Link_Referencia\");\r",
                "    });\r",
                "\r",
                "}"
